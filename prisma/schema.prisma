generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String            @unique
  password      String?
  image         String?
  provider      String?
  createdAt     DateTime          @default(now())
  portfolio     Holding[]
  tradeDecisions TradeDecision[]
  journalEntries JournalEntry[]
  goals         Goal[]
  simulator     SimulatorAccount?
  riskProfile   RiskProfile?
  watchlist     WatchlistItem[]
  chartLevels   ChartLevel[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Holding {
  id               String    @id @default(cuid())
  userId           String
  ticker           String
  name             String
  quantity         Float
  avgPrice         Float
  purchaseDate     DateTime
  assetType        String
  currency         String    @default("USD")
  manualPrice      Float?
  // Extended fields for non-market asset types
  managingBody     String?   // גוף מנהל (pension/gemel/bank)
  accountNumber    String?   // מספר קופה / חשבון
  track            String?   // מסלול השקעה
  monthlyDeposit   Float?    // הפקדה חודשית
  depositFrequency String?   // monthly | quarterly | yearly
  interestRate     Float?    // ריבית שנתית %
  maturityDate     DateTime? // תאריך סיום פיקדון
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SimulatorAccount {
  id      String           @id @default(cuid())
  userId  String           @unique
  balance Float            @default(10000)
  trades  SimulatorTrade[]
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SimulatorTrade {
  id        String           @id @default(cuid())
  accountId String
  ticker    String
  action    String
  quantity  Float
  price     Float
  timestamp DateTime         @default(now())
  account   SimulatorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model RiskProfile {
  id      String @id @default(cuid())
  userId  String @unique
  score   Int
  label   String
  answers String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id          String    @id @default(cuid())
  userId      String
  createdAt   DateTime  @default(now())
  ticker      String
  action      String
  price       Float
  thesis      String
  risk        String
  target      Float
  reviewDate  DateTime
  outcome     String?
  closePrice  Float?
  emotionTag    String
  status        String    @default("open")
  currency      String    @default("USD")
  followedPlan  Boolean?
  movedStop     String?
  exitReason    String?
  exitNotes     String?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TradeDecision {
  id            String   @id @default(cuid())
  userId        String
  ticker        String
  entryPrice    Float
  stopLoss      Float
  target        Float
  portfolioSize Float
  riskPercent   Float
  rrRatio       Float
  positionSize  Float
  positionPct   Float
  passed        Boolean
  aiSummary     String
  currency      String   @default("USD")
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id             String   @id @default(cuid())
  userId         String
  createdAt      DateTime @default(now())
  name           String
  targetAmount   Float
  currentAmount  Float    @default(0)
  monthlyDeposit Float    @default(0)
  targetDate     DateTime
  expectedReturn    Float    @default(7)
  currency          String   @default("ILS")
  icon              String   @default("💰")
  status            String   @default("active")
  depositFrequency  String   @default("monthly")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WatchlistItem {
  id      String   @id @default(cuid())
  userId  String
  ticker  String
  addedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
}

model AiScore {
  id        String   @id @default(cuid())
  symbol    String
  type      String   @default("score") // score | why
  scoreJson String
  createdAt DateTime @default(now())

  @@unique([symbol, type])
}

model ChartLevel {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  type      String   // entry | stop | target
  price     Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, type])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  score       Int?
  completedAt DateTime?

  @@unique([userId, lessonId])
}

model VirtualPortfolio {
  id        String   @id @default(cuid())
  userId    String   @unique
  cashILS   Float    @default(100000)
  holdings  String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VirtualTrade {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  action    String
  price     Float
  quantity  Float
  createdAt DateTime @default(now())
}
